# ─────────────────────────────────────────────────────────────────
# Курьерский бот — переменные окружения
# Скопируйте этот файл в .env и заполните значения для своего сервера.
# ─────────────────────────────────────────────────────────────────

# === Telegram ===
# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# Telegram-IDs администраторов через запятую (например: 12345,67890)
# Только они видят /sheet, /sheet_access, /chatid и получают
# уведомления о новых пользователях и обновлениях бота.
ADMIN_IDS=

# Прокси для Telegram (опционально). Поддерживает HTTP/HTTPS/SOCKS5.
# Пример: socks5://user:pass@host:1080
TELEGRAM_PROXY_URL=

# === Чаты для пересылки фото (опционально) ===
# WORK_CHAT_ID — куда уходят фото пробега
# ROUTE_SHEET_CHAT_ID — фото маршрутных листов
# RECONCILIATION_CHAT_ID — фото сверок (Терминал/Пин-Панель)
# THREAD_ID — id топика в чате с топиками (опционально)
# Если ROUTE_SHEET_CHAT_ID или RECONCILIATION_CHAT_ID не заданы —
# фото уходят в WORK_CHAT_ID как fallback.
WORK_CHAT_ID=
WORK_THREAD_ID=
ROUTE_SHEET_CHAT_ID=
ROUTE_SHEET_THREAD_ID=
RECONCILIATION_CHAT_ID=
RECONCILIATION_THREAD_ID=

# === Google Sheets ===
# Сервисный аккаунт для доступа к Google Sheets API.
# Создаётся в Google Cloud Console, потом надо дать его e-mail
# доступ "Editor" к нужным таблицам.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Часовой пояс для расчёта дня смены и округления времени
APP_TIMEZONE=Europe/Moscow

# === OCR — распознавание пробега по фото ===
# RapidOCR (запускается как локальный HTTP-сервер на VPS)
RAPIDOCR_ENABLED=true
RAPIDOCR_URL=http://127.0.0.1:9527

# Валидация распознанного значения
OCR_MIN_MILEAGE=5000          # минимально допустимый пробег в км
OCR_MAX_SHIFT_DELTA=800       # максимальный прирост пробега за смену в км

# Пороги уверенности OCR — кандидат должен пройти оба
RAPIDOCR_MIN_COUNT=2          # минимум разных распознаваний одного числа
RAPIDOCR_MIN_AVG_CONF=0.58    # средняя уверенность
RAPIDOCR_MIN_MAX_CONF=0.72    # максимальная уверенность

# === UX-настройки ===
# Тон сообщений: false = деловой (по умолчанию), true = с шутками
# («Котоконтроль не дремлет», «Ай-ай, денюжки» и пр.)
FUN_TONE=false

# Кастомные пункты в уведомлении об обновлении (через символ "|")
# Пример: UPDATE_NOTES=Починили баг X|Ускорили Y|Добавили Z
UPDATE_NOTES=

# === Стикер- и GIF-реакции (необязательно) ===
# По умолчанию выключены. Включаются только если есть контент в
# каком-либо из списков ниже.
FUN_REACTIONS_ENABLED=false
FUN_REACTION_COOLDOWN_MS=30000
FUN_IMPORT_STICKER_SETS=true
FUN_STICKER_SETS=https://t.me/addstickers/TikTok_cats_animals
FUN_ERROR_STICKERS=
FUN_ERROR_GIFS=
FUN_SUCCESS_STICKERS=
FUN_SUCCESS_GIFS=

# === Проблема с заказом — ссылки на чаты ===
# При нажатии кнопки «Проблема с заказом» бот показывает inline-кнопки
# с ссылками на нужные чаты. Если URL не задан — кнопка не показывается.
ISSUE_DELIVERY_URL=https://t.me/c/1703163982/1
ISSUE_FLOWWOW_URL=https://t.me/c/1703163982/182754
ISSUE_TECHSUPPORT_URL=https://t.me/HelpRetail_bot
